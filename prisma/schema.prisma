// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}


model Settings {
  id                       String   @id @default(cuid())
  whatsappToken            String   @default("")
  phoneNumberId            String   @default("")
  orderConfirmationMessage String   @default("")
  orderConfirmationEnabled Boolean  @default(true)
  fulfillmentMessage       String   @default("")
  fulfillmentEnabled       Boolean  @default(true)
  cancellationMessage      String   @default("")
  cancellationEnabled      Boolean  @default(true)
  abandonedCartMessage     String   @default("")
  abandonedCartEnabled     Boolean  @default(false)
  abandonedCartDelay       Int      @default(60)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  confirmButtonText  String  @default("✅ Yes, Confirm")
  cancelButtonText   String  @default("❌ No, Cancel")
  adminNotificationEnabled  Boolean  @default(false)
adminNotificationMessage  String   @default("")
adminNumbers              String   @default("")
}

model OrderResponse {
  id           String   @id @default(cuid())
  shop         String
  orderName    String
  customerName String
  phone        String
  response     String   // "confirmed" or "cancelled"
  createdAt    DateTime @default(now())
}

model AbandonedCart {
  id           String    @id @default(cuid())
  shop         String
  cartToken    String    @unique
  customerName String
  phone        String
  items        String
  total        String
  checkoutUrl  String
  messageSent  Boolean   @default(false)
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model MessageLog {
  id           String   @id @default(cuid())
  shop         String
  orderName    String
  customerName String
  phone        String
  messageType  String
  status       String
  createdAt    DateTime @default(now())
}


